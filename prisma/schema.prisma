// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  avatarUrl String?
  projects  Project[]
  researches Research[]
  agentConfigs AgentConfig[]
  workflows    Workflow[]
  workflowRuns WorkflowRun[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Project {
  id              String   @id @default(uuid())
  title           String
  description     String?
  category        String?
  platform        String?
  targetAudience  String?
  status          String   @default("draft") // draft, active, archived
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos          Video[]
  ideas           Idea[]
  scripts         Script[]
  thumbnails      Thumbnail[]
  seoAssets       SEOAsset[]
  contentPackages ContentPackage[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
model Video {
  id            String    @id @default(uuid())
  title         String
  description   String?
  status        String    @default("ideas") // ideas, researching, writing, recording, editing, scheduled, published
  platform      String?
  thumbnail     String?
  script        String?   @db.Text
  publishedDate DateTime?
  views         Int       @default(0)
  ctr           Float     @default(0)
  watchTime     Int       @default(0) // in minutes
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks         Task[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Idea {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("new") // new, researching, approved, archived
  platform    String?
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id        String   @id @default(uuid())
  title     String
  isDone    Boolean  @default(false)
  videoId   String?
  video     Video?   @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Research {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     String
  summary   String?  @db.Text
  keywords  Json?
  ideas     Json?
  createdAt DateTime @default(now())
}

model Script {
  id        String   @id @default(uuid())
  title     String
  hook      String?  @db.Text
  content   String   @db.Text
  style     String?
  status    String   @default("draft") // draft, generated, completed
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Thumbnail {
  id          String   @id @default(uuid())
  concept     String   @db.Text
  headline    String
  emotion     String?
  composition String?  @db.Text
  objects     String?  @db.Text
  prompt      String   @db.Text
  tips        Json?
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SEOAsset {
  id            String   @id @default(uuid())
  title         String
  description   String   @db.Text
  tags          Json?
  keywords      Json?
  hashtags      Json?
  pinnedComment String?  @db.Text
  communityPost String?  @db.Text
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AgentConfig {
  id           String   @id @default(uuid())
  name         String
  type         String   // "research", "script", "seo", etc.
  status       String   @default("active") // active, inactive
  model        String   @default("gpt-4o")
  provider     String   @default("openai")
  temperature  Float    @default(0.7)
  instructions String?  @db.Text
  lastRun      DateTime?
  usage        Int      @default(0)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs         AgentLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Workflow {
  id              String   @id @default(uuid())
  name            String
  description     String?
  trigger         String   // e.g., "manual", "new_topic_added", "scheduled"
  steps           Json     // Array of agent types or step configurations
  isActive        Boolean  @default(true)
  executionCount  Int      @default(0)
  lastExecution   DateTime?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs            WorkflowRun[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WorkflowRun {
  id          String   @id @default(uuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status      String   @default("pending") // pending, running, completed, failed
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AgentLog {
  id              String   @id @default(uuid())
  agentConfigId   String
  agentConfig     AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)
  agentType       String   // "research", "script", etc.
  status          String   @default("pending") // pending, running, completed, failed
  input           Json?
  output          Json?
  error           String?
  tokensUsed      Int      @default(0)
  executionTime   Int      @default(0) // in ms
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ContentPackage {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflowId  String?
  status      String   @default("draft") // draft, processing, completed
  researchId  String?
  scriptId    String?
  thumbnailId String?
  seoAssetId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
